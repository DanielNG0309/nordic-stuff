/ {
	cpus {
		power-states {
			wait: wait {
				compatible = "zephyr,power-state";
				power-state-name = "standby";
				substate-id = <0>;
				min-residency-us = <2000>;
			};

			flpr_sleep: flpr_sleep {
				compatible = "zephyr,power-state";
				power-state-name = "suspend-to-ram";
				substate-id = <1>;
				min-residency-us = <400000>;
			};

			flpr_deep_sleep: flpr_deep_sleep {
				compatible = "zephyr,power-state";
				power-state-name = "suspend-to-ram";
				substate-id = <2>;
				min-residency-us = <600000>;
			};

			flpr_hibernate: flpr_hibernate {
				compatible = "zephyr,power-state";
				power-state-name = "suspend-to-ram";
				substate-id = <3>;
				min-residency-us = <1000000>;
			};
		};
	};
};

&cpu {
	cpu-power-states = <&wait &flpr_sleep &flpr_deep_sleep &flpr_hibernate>;
};
